rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if false;
    }

    // ── Bucket list items (ideas + completions) ───────────────────────────────
    // Any signed-in user can read completed posts (public social feed).
    // Only owner can read uncompleted ideas (private to-do list).
    match /userBucketlistItems/{itemId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        resource.data.completed == true ||
        resource.data.collectionId != null
      );
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        resource.data.completed == true ||
        resource.data.collectionId != null
      );
      allow delete: if isSignedIn() && isOwner(resource.data.userId);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(request.resource.data.userId);
        allow update: if false;
        allow delete: if isSignedIn() && (
          isOwner(resource.data.userId) ||
          isOwner(get(/databases/$(database)/documents/userBucketlistItems/$(itemId)).data.userId)
        );
      }

      match /likes/{likeId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(likeId);
        allow delete: if isSignedIn() && isOwner(likeId);
        allow update: if false;
      }
    }

    // ── Collections ───────────────────────────────────────────────────────────
    // Any signed-in user can read (privacy enforced in app UI, not rules).
    // Only owner can delete. Owner or members can update.
    match /collections/{collectionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if isSignedIn() && isOwner(resource.data.userId);
      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // ── Follows ───────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(request.resource.data.followerId);
      allow delete: if isSignedIn() && isOwner(resource.data.followerId);
      allow update: if false;
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && isOwner(resource.data.recipientId);
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && isOwner(resource.data.recipientId);
    }

    // ── Experiences (Discover) ────────────────────────────────────────────────
    match /experiences/{experienceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && isOwner(resource.data.createdBy);
    }

    // ── Collection invites ────────────────────────────────────────────────────
    match /collectionInvites/{inviteId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.invitedUserId) ||
        isOwner(resource.data.invitedBy)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(resource.data.invitedUserId);
      allow delete: if isSignedIn() && (
        isOwner(resource.data.invitedUserId) ||
        isOwner(resource.data.invitedBy)
      );
    }
  }
}
